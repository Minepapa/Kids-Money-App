<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDFBFF"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 저축 목표 섹션 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:text="🎯 저축 목표"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btnAddGoal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ 목표 추가"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGoals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvNoGoals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="아직 저축 목표가 없어요!\n목표를 추가해보세요 😊"
            android:gravity="center"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:padding="16dp"
            android:visibility="gone"/>

        <!-- 소비 분석 차트 -->
        <TextView
            android:text="📊 이번 달 소비 분석"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChart"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvNoChart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="이번 달 기록이 없어요 📝"
            android:gravity="center"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:padding="16dp"
            android:visibility="gone"/>

        <!-- 업적 뱃지 섹션 -->
        <TextView
            android:text="🏆 나의 뱃지"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvBadges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>

</ScrollView>
