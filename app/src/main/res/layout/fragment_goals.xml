<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sb_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <!-- 상단 히어로 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_hero"
            android:padding="20dp"
            android:paddingBottom="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:text="🎯 저축 목표"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/sb_text_on_dark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btnAddGoal"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="+ 추가"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/sb_dark_green"
                android:background="@color/sb_text_on_dark"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>

        <!-- 목표 리스트 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="-16dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGoals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvNoGoals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="아직 저축 목표가 없어요!\n목표를 추가해보세요 😊"
                android:gravity="center"
                android:textColor="@color/sb_text_hint"
                android:textSize="13sp"
                android:padding="24dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- 소비 분석 섹션 -->
        <TextView
            android:text="📊 이번 달 소비 분석"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/sb_text_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"/>

        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChart"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvNoChart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="이번 달 기록이 없어요 📝"
            android:gravity="center"
            android:textColor="@color/sb_text_hint"
            android:textSize="13sp"
            android:padding="16dp"
            android:visibility="gone"/>

        <!-- 뱃지 섹션 -->
        <TextView
            android:text="🏆 나의 뱃지"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/sb_text_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvBadges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>

    </LinearLayout>

</ScrollView>
