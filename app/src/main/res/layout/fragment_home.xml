<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sb_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 히어로 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_hero"
            android:padding="20dp"
            android:paddingBottom="36dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:text="안녕, 미네야!"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/sb_text_on_dark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="오늘도 용돈을 기록해봐요"
                    android:textSize="13sp"
                    android:textColor="@color/sb_text_on_dark_soft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/tvTodayDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/sb_text_on_dark_soft"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <FrameLayout
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_avatar_circle"
                android:layout_marginStart="8dp">

                <ImageView
                    android:id="@+id/ivProfileAvatar"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_avatar_girl"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"/>

            </FrameLayout>

        </LinearLayout>

        <!-- 잔액 카드 (히어로 위 오버랩) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="-24dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <!-- 아빠 금고 카드 -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/sb_gold_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="top">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:text="아빠 금고"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/sb_text_secondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                        <TextView
                            android:id="@+id/btnBankSettings"
                            android:text="⚙️"
                            android:textSize="14sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvBank"
                        android:text="0원"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_bank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/tvDailyInterest"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textColor="@color/sb_gold"
                        android:layout_marginTop="2dp"
                        android:visibility="invisible"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 남은 용돈 카드 -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/sb_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="top">

                    <TextView
                        android:text="남은 용돈"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/sb_text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tvWallet"
                        android:text="0원"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/sb_medium_green"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/tvStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textColor="@color/sb_gold"
                        android:layout_marginTop="2dp"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvLatestBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textColor="@color/sb_medium_green"
                        android:layout_marginTop="2dp"
                        android:visibility="gone"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- 입력 폼 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/sb_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 날짜 선택 -->
                <TextView
                    android:text="날짜"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/sb_text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/etDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:background="@drawable/bg_input_field"
                    android:textSize="14sp"
                    android:textColor="@color/sb_text_primary"
                    android:hint="날짜를 선택하세요"
                    android:textColorHint="@color/sb_text_hint"
                    android:layout_marginBottom="12dp"/>

                <!-- 거래 유형 토글 -->
                <TextView
                    android:text="종류"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/sb_text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/typeToggleGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    android:layout_marginBottom="12dp">

                    <Button
                        android:id="@+id/btnTypeIncome"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📈 수입"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                    <Button
                        android:id="@+id/btnTypeExpense"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📉 지출"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                    <Button
                        android:id="@+id/btnTypeBank"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🏦 저축"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- 내용 -->
                <TextView
                    android:text="내용"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/sb_text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etMemo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="무엇을 했나요?"
                    android:textColorHint="@color/sb_text_hint"
                    android:textColor="@color/sb_text_primary"
                    android:background="@drawable/bg_input_field"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp"/>

                <!-- 금액 -->
                <TextView
                    android:text="금액"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/sb_text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="직접 입력 (원)"
                    android:textColorHint="@color/sb_text_hint"
                    android:textColor="@color/sb_text_primary"
                    android:inputType="number"
                    android:background="@drawable/bg_input_field"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnAdd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="기록하기"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/sb_white"
                    android:background="@drawable/bg_button_primary"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 당일 내역 카드 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/detailView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/sb_white"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvDetailDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/sb_text_primary"
                    android:paddingBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/llDayList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
