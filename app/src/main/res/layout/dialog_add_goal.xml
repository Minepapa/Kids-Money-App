<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:text="새 저축 목표"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/sb_text_primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/etGoalTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="무엇을 살까요? (예: 레고, 게임)"
        android:textColorHint="@color/sb_text_hint"
        android:textColor="@color/sb_text_primary"
        android:background="@drawable/bg_input_field"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:layout_marginBottom="14dp"/>

    <EditText
        android:id="@+id/etGoalAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="얼마가 필요해요? (원)"
        android:textColorHint="@color/sb_text_hint"
        android:textColor="@color/sb_text_primary"
        android:background="@drawable/bg_input_field"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:inputType="number"/>

</LinearLayout>
