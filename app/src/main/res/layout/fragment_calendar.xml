<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sb_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 달력 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_hero"
            android:padding="16dp"
            android:paddingBottom="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnPrevMonth"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="‹"
                android:textSize="20sp"
                android:textColor="@color/sb_text_on_dark"
                android:background="@drawable/bg_button_outline_green"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <TextView
                android:id="@+id/tvMonth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/sb_text_on_dark"/>

            <Button
                android:id="@+id/btnNextMonth"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="›"
                android:textSize="20sp"
                android:textColor="@color/sb_text_on_dark"
                android:background="@drawable/bg_button_outline_green"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

        </LinearLayout>

        <!-- 달력 그리드 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/sb_white"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="-20dp"
            android:layout_marginBottom="10dp">

            <GridLayout
                android:id="@+id/calendarGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="7"
                android:padding="8dp"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- 월별 요약 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/sb_white"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvMonthInc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="@color/color_income"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp"/>

                <TextView
                    android:id="@+id/tvMonthExp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="@color/color_expense"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp"/>

                <TextView
                    android:id="@+id/tvMonthBnk"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="@color/color_bank"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 날짜 상세 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/detailView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/sb_white"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDetailDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/sb_text_primary"
                    android:paddingBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/llDayList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
